{
  "name": "react",
  "version": "0.1.0",
  "private": true,
  "description": "routing を使うために next を利用",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "fix": "run-p \"fix:*\" -c --aggregate-output",
    "fix:prettier": "pnpm lint:prettier --write",
    "fix:sort-package-json": "sort-package-json ./package.json",
    "fix:stylelint": "pnpm lint:stylelint --fix",
    "lint": "run-p \"lint:*\" -c --aggregate-output",
    "lint:eslint": "eslint",
    "lint:prettier": "prettier --check \"./*.{cjs,mts,ts,tsx}\"",
    "lint:sort-package-json": "pnpm fix:sort-package-json --check",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "next": "catalog:react",
    "react": "catalog:react",
    "react-dom": "catalog:react"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "catalog:react",
    "@storybook/addon-a11y": "catalog:react",
    "@storybook/addon-docs": "catalog:react",
    "@storybook/addon-mcp": "catalog:react",
    "@storybook/addon-vitest": "catalog:react",
    "@storybook/nextjs-vite": "catalog:react",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitest/browser-playwright": "catalog:react",
    "@vitest/coverage-v8": "catalog:react",
    "eslint": "catalog:production-infrastructure",
    "eslint-config-next": "catalog:react",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-storybook": "catalog:react",
    "npm-run-all2": "catalog:",
    "playwright": "catalog:react",
    "prettier": "catalog:",
    "sort-package-json": "catalog:",
    "storybook": "catalog:react",
    "stylelint": "catalog:react",
    "stylelint-config-css-modules": "catalog:react",
    "stylelint-config-standard": "catalog:react",
    "typescript": "catalog:",
    "vite": "catalog:react",
    "vitest": "catalog:react"
  }
}
