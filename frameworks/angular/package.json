{
  "name": "angular",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "ng build",
    "fix": "run-p \"fix:*\" -c --aggregate-output",
    "fix:prettier": "pnpm lint:prettier --write",
    "fix:sort-package-json": "sort-package-json ./package.json",
    "fix:stylelint": "pnpm lint:stylelint --fix",
    "lint": "run-p \"lint:*\" -c --aggregate-output",
    "lint:eslint": "ng lint",
    "lint:prettier": "prettier --check \"./**/*.{js,cjs,mjs,ts,html}\"",
    "lint:sort-package-json": "pnpm fix:sort-package-json --check",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "ng": "ng",
    "start": "ng serve",
    "test": "ng test",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/common": "catalog:angular",
    "@angular/compiler": "catalog:angular",
    "@angular/core": "catalog:angular",
    "@angular/forms": "catalog:angular",
    "@angular/platform-browser": "catalog:angular",
    "@angular/router": "catalog:angular",
    "date-fns": "catalog:production-infrastructure",
    "rxjs": "catalog:angular",
    "tslib": "catalog:angular"
  },
  "devDependencies": {
    "@angular-eslint/builder": "catalog:angular",
    "@angular/build": "catalog:angular",
    "@angular/cli": "catalog:angular",
    "@angular/compiler-cli": "catalog:angular",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "jsdom": "catalog:angular",
    "npm-run-all2": "catalog:",
    "prettier": "catalog:",
    "sort-package-json": "catalog:",
    "stylelint": "catalog:angular",
    "stylelint-config-standard": "catalog:angular",
    "typescript": "catalog:production-infrastructure",
    "typescript-eslint": "catalog:production-infrastructure",
    "vitest": "catalog:angular"
  },
  "packageManager": "pnpm@11.9.0"
}
